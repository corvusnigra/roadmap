# --- Supabase (Postgres + Auth) ---
# Direct Postgres connection string for Drizzle migrations & server runtime.
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres"
NEXT_PUBLIC_SUPABASE_URL="http://localhost:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Anthropic (AI tutor) ---
ANTHROPIC_API_KEY=""

# --- Stripe ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- PostHog (analytics) ---
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# --- Demo mode ---
# "on"  → гостевой доступ без логина (используется на prod до запуска платного плана)
# "off" → обычный режим с обязательной аутентификацией (по умолчанию)
# Установите NEXT_PUBLIC_DEMO_MODE=on в Vercel для текущего prod-деплоя.
NEXT_PUBLIC_DEMO_MODE="off"

# --- Database logging ---
# Раскомментируйте для отладки SQL-запросов в локальной среде.
# НЕ устанавливайте в production — засоряет логи.
# DB_LOG="true"
